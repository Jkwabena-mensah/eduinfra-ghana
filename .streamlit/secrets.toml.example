# =============================================================================
# EduInfra Ghana — Streamlit Secrets Template
# =============================================================================
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. Replace the placeholder value with your real Anthropic API key
#   3. secrets.toml is already in .gitignore — never commit it
# =============================================================================

# Required: enables the "Ask EduInfra" AI Chat Assistant in the sidebar
# Get your key at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY = "sk-ant-api03-REPLACE_WITH_YOUR_KEY_HERE"

# Optional: override default data paths (leave commented unless needed)
# DATA_DIR = "data"
# MODEL_DIR = "models"
