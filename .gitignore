# Models — ALLOW the two app pkl files (unblocked with !)
# *.pkl  <-- removed so models/eduinfra_v1.pkl and v2.pkl are tracked
!models/eduinfra_v1.pkl
!models/eduinfra_v2.pkl

# Large data folders — allow specific critical CSVs
data/dhs/
data/boundaries/
data/electrification/
data/poverty/

# Allow key ranked/scored CSVs that the app needs at runtime
